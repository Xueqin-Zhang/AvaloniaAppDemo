<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:mv="clr-namespace:AvaloniaAppDemo.views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AvaloniaAppDemo.MainWindow"
        x:DataType="mv:MainWindowViewModel"
        Title="AvaloniaAppDemo">
    <Grid Background="{DynamicResource PrimaryBackground}" ColumnDefinitions="200, *">
        <Border Classes="SideMenuBorder" Background="{DynamicResource PrimarySideMenuBackground}">
            <Grid RowDefinitions="*, Auto">
                <StackPanel Spacing="10">
                    <Image Source="{SvgImage /Assets/Images/logo.svg}"></Image>
                    <IconButton HorizontalAlignment="Stretch" Icon="&#xe2c2;" Content="Home"></IconButton>
                    <IconButton HorizontalAlignment="Stretch" Icon="&#xe572;" Content="Actions"></IconButton>
                    <IconButton HorizontalAlignment="Stretch" Icon="&#xe012;" Content="Macros"></IconButton>
                    <IconButton HorizontalAlignment="Stretch" Icon="&#xe9fc;" Content="Reporter"></IconButton>
                    <IconButton HorizontalAlignment="Stretch" Icon="&#xE7F4;" Content="History"></IconButton>
                </StackPanel>
                
                <Button Grid.Row="1" HorizontalAlignment="Left">
                    <Label Classes="icon" Content="&#xE270;"></Label>
                </Button>
            </Grid>
        </Border>
        
        <Grid Column="1">
            <Border Background="Gray">
                <ContentControl Content="{Binding CurrentPage}"></ContentControl>
            </Border>
        </Grid>
    </Grid>
</Window>
