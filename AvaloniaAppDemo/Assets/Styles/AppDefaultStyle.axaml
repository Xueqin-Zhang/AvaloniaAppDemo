<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:AvaloniaAppDemo">
    <Design.PreviewWith>
        <Border Background="{DynamicResource PrimaryBackground}">
            <Grid ColumnDefinitions="Auto, Auto" Width="300">
                <StackPanel  Spacing="12">
                    <IconButton Content="normal" Icon="&#xE512;"/>
                    <IconButton Content="normal" Classes="isAction" Icon="&#xE512;"/>
                    <IconButton Content="normal" Classes="primary" Icon="&#xE512;"/>
                    <IconButton Content="subtle" Classes="subtle" Icon="&#xE512;"/>
                    <IconButton Content="Outline" Classes="outline" Icon="&#xE512;"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1">
                    <CheckBox>后选课</CheckBox>
                </StackPanel>
            </Grid>
        </Border>
        
    </Design.PreviewWith>

    <Style Selector="Border.SideMenuBorder">
        <Setter Property="Padding" Value="10, 20, 10, 20"></Setter>
    </Style>
    <Style Selector="Label.icon">
        <Setter Property="FontFamily" Value="{DynamicResource Phosphor}"></Setter>
    </Style>
</Styles>
